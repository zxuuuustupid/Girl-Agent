# =============================================
# GirlAgent - .gitignore
# 规则：只允许添加，不允许删除
# =============================================

# =============================================
# Python 缓存和字节码
# =============================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# =============================================
# 虚拟环境和 Conda
# =============================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# =============================================
# 项目特定的配置和临时文件
# =============================================
src/config/
src/build/
src/dist/
src/main.spec
*.spec.bak
*.manifest
*.pkg

# =============================================
# Personality 模块（只保留核心性格）
# =============================================
src/prompts/personalities/*
# !src/prompts/personalities/cute.py
# !src/prompts/personalities/mature.py

# =============================================
# Backdoor 相关文件
# =============================================
src/main_backdoor.py
src/run_backdoor.bat

# =============================================
# 测试相关
# =============================================
tests/test_rag.py
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# =============================================
# 环境变量和密钥
# =============================================
.env
.env.*
*.env
settings.py

# =============================================
# IDE 和编辑器
# =============================================
.idea/
.vscode/
*.code-workspace
src/.vscode/settings.json
src/.claude/settings.local.json

# =============================================
# 构建输出
# =============================================
exe/
out/

# =============================================
# 操作系统文件
# =============================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================
# 日志文件
# =============================================
*.log
logs/

# =============================================
# Additional ignores (append-only)
# =============================================
build/
dist/
*.pyz
*.tmp
*.bak
*.orig
__pycache__/

# PyInstaller / packaging temp files
*.toc
*.pyz
*.pkg
warn-*.txt
xref-*.html

# Runtime logs
startup.log

# Local env files
.env
.env.*
